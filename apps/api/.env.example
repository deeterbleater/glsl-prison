NODE_ENV=development
PORT=8080
HOST=127.0.0.1

DATABASE_URL=postgresql://shader_oracle:password@localhost:5432/shader_oracle

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_TITLE="Shader Oracle"
DEFAULT_MODEL=gpt-5-mini
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.2

CORS_ORIGIN=http://localhost:5173,https://your-vercel-domain.vercel.app,https://shader-oracle.com

CAPTURE_STORAGE_DIR=/var/lib/shader-oracle/captures
PUBLIC_CAPTURE_BASE_URL=https://api.yourdomain.com/captures

RATE_LIMIT_PER_MINUTE=20
PUBLIC_WEB_BASE_URL=http://localhost:5173
