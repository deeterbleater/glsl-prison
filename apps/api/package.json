{
  "name": "@shader-oracle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "prisma generate --config prisma.config.ts && tsc -p tsconfig.json && cp -R src/generated dist/generated",
    "start": "node dist/index.js",
    "typecheck": "prisma generate --config prisma.config.ts && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config prisma.config.ts"
  },
  "dependencies": {
    "@clerk/fastify": "^3.1.40",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@shader-oracle/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-raw-body": "^5.0.0",
    "pg": "^8.22.0",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "schema": "src/db/schema.prisma"
  }
}
