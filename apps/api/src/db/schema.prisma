generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id        String    @id
  userId    String?
  prompt    String
  mode      String
  model     String?
  public    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  attempts  Attempt[]

  @@index([userId])
}

model Attempt {
  id            String    @id
  runId         String
  run           Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  attemptNumber Int
  fragment      String
  mode          String
  model         String?
  status        String
  compileOk     Boolean?
  compileLog    String?
  statsJson     Json?
  scoreJson     Json?
  critique      String?
  createdAt     DateTime  @default(now())
  captures      Capture[]

  @@index([runId])
}

model Capture {
  id        String   @id
  attemptId String
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  t         Float
  imageUrl  String?
  dataUrl   String?
  createdAt DateTime @default(now())

  @@index([attemptId])
}

model TokenBalance {
  userId        String             @id
  balanceTokens Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  entries       TokenLedgerEntry[]
}

model TokenLedgerEntry {
  id              String       @id
  userId          String
  balance         TokenBalance @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type            String
  tokenDelta      Int
  balanceAfter    Int
  model           String?
  runId           String?
  attemptId       String?
  promptTokens    Int?
  completionTokens Int?
  totalTokens     Int?
  costUsdMicros   Int?
  stripeEventId   String?      @unique
  stripeSessionId String?      @unique
  amountUsdCents  Int?
  description     String?
  createdAt       DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([runId])
  @@index([attemptId])
}
